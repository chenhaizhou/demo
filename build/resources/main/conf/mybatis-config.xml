<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration 
PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <settings>
        <setting name="logImpl" value="SLF4J"/>
    </settings>

    <!-- 命名空间 -->
    <typeAliases>
         <typeAlias alias="UserEntity" type="com.thoughtworks.dolphin.model.UserEntity"/>
         <typeAlias alias="Book" type="com.thoughtworks.dolphin.model.Book"/>
         <typeAlias alias="Image" type="com.thoughtworks.dolphin.model.Image"/>
    </typeAliases>

    <!-- 映射map -->
    <mappers>
        <package name="com.thoughtworks.dolphin.dao"/>
    </mappers>
</configuration>